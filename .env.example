# Kopieer naar .env voor lokaal gebruik — commit dit nooit met echte waarden.
# In GitHub Actions horen deze als Repository secrets, niet als .env-bestand.

SHOPIFY_STORE_DOMAIN=byleijtens.myshopify.com

# Nieuwe custom apps (aangemaakt via Dev Dashboard, sinds 2026-01-01):
# client credentials grant — Dev Dashboard > jouw app > Instellingen.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Legacy custom apps (aangemaakt vóór 2026-01-01): statisch token.
# Alleen nodig als SHOPIFY_CLIENT_ID/SHOPIFY_CLIENT_SECRET hierboven leeg zijn.
SHOPIFY_ADMIN_ACCESS_TOKEN=

SHOPIFY_API_VERSION=2025-10
PAGE_SIZE=50
OUTPUT_DIR=reports

# Optioneel — alleen nodig voor src/update-list.js
ANTHROPIC_API_KEY=

# Optioneel — zet op true als de Action zichtbaar rood moet uitslaan bij bevindingen
FAIL_ON_VIOLATION=false
